{
  "name": "footprint-samples",
  "version": "1.0.0",
  "private": true,
  "description": "Runnable examples for the footprint library",
  "scripts": {
    "quick-start": "npx tsx examples/quick-start/loan-application.ts",
    "feature:values": "npx tsx examples/features/01-values.ts",
    "feature:narrative": "npx tsx examples/features/02-narrative.ts",
    "feature:recorders": "npx tsx examples/features/03-recorders.ts",
    "feature:typed-scope": "npx tsx examples/features/04-typed-scope.ts",
    "feature:metrics": "npx tsx examples/features/05-metrics.ts",
    "feature:streaming": "npx tsx examples/features/06-streaming.ts",
    "feature:errors": "npx tsx examples/features/07-error-handling.ts",
    "feature:debug": "npx tsx examples/features/08-debug-and-mermaid.ts",
    "feature:break": "npx tsx examples/features/09-break-fn.ts",
    "feature:contract": "npx tsx examples/features/10-contract-openapi.ts",
    "feature:flow-recorders": "npx tsx examples/features/11-flow-recorders.ts",
    "feature:redaction": "npx tsx examples/features/12-redaction.ts",
    "fr:simple": "npx tsx examples/flow-recorders/01-simple-observer.ts",
    "fr:compare": "npx tsx examples/flow-recorders/02-strategy-comparison.ts",
    "fr:custom": "npx tsx examples/flow-recorders/03-custom-recorder.ts",
    "fr:multiple": "npx tsx examples/flow-recorders/04-multiple-recorders.ts",
    "fr:edge-cases": "npx tsx examples/flow-recorders/05-edge-cases.ts",
    "fr:all": "npm run fr:simple && npm run fr:compare && npm run fr:custom && npm run fr:multiple && npm run fr:edge-cases",
    "flow:linear": "npx tsx examples/flowchart/01-linear.ts",
    "flow:fork": "npx tsx examples/flowchart/02-fork.ts",
    "flow:decider": "npx tsx examples/flowchart/03-decider.ts",
    "flow:selector": "npx tsx examples/flowchart/04-selector.ts",
    "flow:subflow": "npx tsx examples/flowchart/05-subflow.ts",
    "flow:loops": "npx tsx examples/flowchart/06-loops.ts",
    "all": "npm run quick-start && npm run feature:values && npm run feature:narrative && npm run feature:recorders && npm run feature:typed-scope && npm run feature:metrics && npm run feature:streaming && npm run feature:errors && npm run feature:debug && npm run feature:break && npm run feature:contract && npm run flow:linear && npm run flow:fork && npm run flow:decider && npm run flow:selector && npm run flow:subflow && npm run flow:loops"
  },
  "dependencies": {
    "footprint": "file:../footPrint",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
